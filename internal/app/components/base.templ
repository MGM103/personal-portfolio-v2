package components

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<link rel="stylesheet" href="/static/stylesheets/_global.css"/>
			<script src="/static/scripts/htmx.min.js"></script>
			<title>{ title }</title>
		</head>
		<body>
			@Navbar()
			<main>
				<h1>Hello world!!</h1>
			</main>
		</body>
	</html>
}
